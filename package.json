{
  "name": "dynatrace-vs-code-auth-provider",
  "displayName": "Dynatrace VS Code Auth Provider",
  "description": "Shared Dynatrace authentication provider for VS Code extensions",
  "version": "0.0.1",
  "publisher": "Dynatrace",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18.0.0"
  },
  "activationEvents": [
    "onCommand:dynatrace.login",
    "onCommand:dynatrace.logout",
    "onAuthenticationRequest:dynatrace.authentication"
  ],
  "contributes": {
    "commands": [
      {
        "command": "dynatrace.login",
        "title": "Log in",
        "category": "Dynatrace"
      },
      {
        "command": "dynatrace.logout",
        "title": "Log out",
        "category": "Dynatrace"
      }
    ],
    "keybindings": [
      {
        "command": "dynatrace.login",
        "key": "ctrl+shift+d ctrl+shift+l",
        "mac": "cmd+shift+d cmd+shift+l",
        "when": "!dynatrace.isLoggedIn"
      },
      {
        "command": "dynatrace.logout",
        "key": "ctrl+shift+d ctrl+shift+o",
        "mac": "cmd+shift+d cmd+shift+o",
        "when": "dynatrace.isLoggedIn"
      }
    ],
    "authentication": [
      {
        "id": "dynatrace.authentication",
        "label": "Dynatrace Login"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "package": "vsce package --allow-missing-repository",
    "test": "echo 'No tests yet'"
  },
  "devDependencies": {
    "@eslint/js": "9.22.0",
    "@types/node": "20.17.9",
    "@types/vscode": "1.85.0",
    "eslint": "9.22.0",
    "@vscode/vsce": "3.7.1",
    "typescript": "5.8.2",
    "typescript-eslint": "8.26.0"
  }
}
